# Resend (https://resend.com/) — email sending for contact form
RESEND_API_KEY=re_your_resend_api_key_here

# Cloudflare Turnstile (https://www.cloudflare.com/products/turnstile/) — bot protection
# Site key is exposed to the browser; only the secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Local development convenience: Cloudflare Turnstile test keys
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Contact email destination (optional, defaults to freoli.official@gmail.com)
CONTACT_EMAIL_TO=freoli.official@gmail.com

# Sender address shown on outgoing mail (optional, default uses Resend's onboarding sender)
# Replace with an address on a domain verified in your Resend account once available.
CONTACT_EMAIL_FROM=FREOLI Contact <onboarding@resend.dev>
