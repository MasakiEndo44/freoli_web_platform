# Resend (https://resend.com/) — email sending for contact form
RESEND_API_KEY=re_your_resend_api_key_here

# Cloudflare Turnstile (https://www.cloudflare.com/products/turnstile/) — bot protection
TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Contact email destination (optional, defaults to freoli.official@gmail.com)
CONTACT_EMAIL_TO=freoli.official@gmail.com
