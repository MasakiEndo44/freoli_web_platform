{
  "permissions": {
    "allow": [
      "Bash(bash .harness-bundle/install.sh --hooks-only)",
      "Bash(bash .harness-bundle/install.sh --templates-only)",
      "Bash(bash .harness-bundle/install.sh --skills=\"goal-grill,requirements-grill,pr-draft-summary,security-sensitive-change-review,integration-nextjs-app-router\")",
      "Bash(node /Users/masaki/Documents/Projects/005_FREOLI/Freoli_platform/.claude/hooks/prevent-destructive-command.js)"
    ]
  },
  "enabledMcpjsonServers": [],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "grep -qE '(sk-[a-zA-Z0-9]{20,}|eyJh[a-zA-Z0-9]{20,}|service_role)' \"$CLAUDE_FILE_PATH\" 2>/dev/null && echo 'BLOCK: Potential secret detected. Use environment variables instead.' && exit 1 || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/prevent-destructive-command.js"
          }
        ]
      }
    ]
  }
}
